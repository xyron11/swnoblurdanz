{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i)(curl|wget|python|go-http-client|postman|sqlmap|nikto|scrapy|aiohttp|httpx|node-fetch|dirsearch|libwww|java)"
        }
      ],
      "destination": "https://http.cat/403",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://convert-api-danz-production.up.railway.app/:path*"
    }
  ]
}
